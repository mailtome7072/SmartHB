# FastAPI 프로덕션 멀티스테이지 빌드 예시
# 사용법: 이 파일을 docker/backend/Dockerfile.prod 로 복사한 후 프로젝트에 맞게 수정하세요.
#
# deploy.yml에서 참조하는 경로: docker/backend/Dockerfile.prod
# build context: 프로젝트 루트 (.)
# target: runtime

# ── 빌드 스테이지 ──────────────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /build

# 의존성만 먼저 설치하여 레이어 캐시 활용
COPY app/backend/requirements.txt .
RUN pip install --upgrade pip && \
    pip install --no-cache-dir --prefix=/install -r requirements.txt

# ── 런타임 스테이지 ─────────────────────────────────────────────
FROM python:3.12-slim AS runtime

WORKDIR /app

# 빌드 스테이지에서 설치한 패키지만 복사
COPY --from=builder /install /usr/local

# 애플리케이션 소스 복사
# TODO: 실제 백엔드 소스 경로에 맞게 수정하세요
COPY app/backend/ .

# 비루트 사용자로 실행 (보안)
RUN addgroup --system app && adduser --system --ingroup app app
USER app

EXPOSE 8000

# TODO: 실제 FastAPI 앱 모듈명으로 수정하세요 (예: main:app → your_module:app)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
