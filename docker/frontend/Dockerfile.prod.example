# Next.js / React 프로덕션 멀티스테이지 빌드 예시
# 사용법: 이 파일을 docker/frontend/Dockerfile.prod 로 복사한 후 프로젝트에 맞게 수정하세요.
#
# deploy.yml에서 참조하는 경로: docker/frontend/Dockerfile.prod
# build context: 프로젝트 루트 (.)
# build-args: NEXT_PUBLIC_API_URL
# target: runtime

# ── 의존성 설치 스테이지 ───────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app

# package.json 위치에 맞게 경로를 수정하세요
# TODO: 프론트엔드 소스가 app/frontend/ 하위라면 아래 경로를 수정하세요
COPY package.json pnpm-lock.yaml* ./
RUN npm install -g pnpm && pnpm install --frozen-lockfile

# ── 빌드 스테이지 ──────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# 런타임에 주입되는 환경변수 (deploy.yml의 build-args에서 전달)
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# TODO: 빌드 명령을 프로젝트에 맞게 수정하세요
RUN npm install -g pnpm && pnpm build

# ── 런타임 스테이지 ─────────────────────────────────────────────
FROM node:20-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production

# Next.js standalone 빌드 결과물만 복사 (용량 최소화)
# TODO: React CRA/Vite의 경우 아래 COPY 대신 nginx 기반으로 변경하세요
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

# 비루트 사용자로 실행 (보안)
RUN addgroup --system app && adduser --system --ingroup app app
USER app

EXPOSE 3000

CMD ["node", "server.js"]
