# ========================================
# 애플리케이션 설정
# ========================================
APP_NAME=SmartHB
DEBUG=false

# ========================================
# SQLite (개발 환경)
# 프로덕션 환경에서는 Tauri의 app_data_dir()이 자동으로 경로를 결정함
# 이 변수는 로컬 개발 시 sqlx migrate run 등에 사용됨
# ========================================
DATABASE_URL=sqlite:./SmartHB-dev.db

# ========================================
# 외부 서비스 (프로젝트에 맞게 추가)
# ========================================
# API_KEY=
