# ========================================
# 애플리케이션 설정
# ========================================
APP_NAME=SmartHB
DEBUG=false

# ========================================
# SQLite (개발 환경)
# 프로덕션 환경에서는 사용자가 초기 설정 마법사(PRD §4.0)에서 지정한
# 클라우드 동기화 폴더(`smarthb/app.db`)를 사용한다 — PRD §5.3.
# 이 DATABASE_URL은 로컬 개발 시 sqlx migrate run / sqlx prepare 등에만 사용됨.
# ========================================
DATABASE_URL=sqlite:./SmartHB-dev.db

# ========================================
# Dev 편의 (V30, Sprint 7 post-review) — 시각 검수 자동 로그인
# ========================================
# 설정 시 `pnpm tauri:dev` 진입 직후 자동으로 PIN 입력 + 잠금 해제 + 락 force-acquire.
# ADR-007: 6자리 숫자 PIN 만 허용 — 그 외 형식이면 자동 로그인 무시.
# 한 번 set_password 한 상태에서만 동작 (NotInitialized 마법사는 사용자 직접 진행).
#
# ⚠️ 보안 경고 (R50, Sprint 7 hotfix):
# `NEXT_PUBLIC_*` 환경 변수는 Next.js 빌드 타임에 클라이언트 번들에 **인라인**된다.
# `.env` 에 설정된 채 `pnpm tauri:build` (release) 를 실행하면 dev PIN 이 인스톨러 JS
# 번들에 포함되어 배포된다. release 빌드 전에 반드시 아래 중 하나를 수행할 것:
#   1) 본 변수를 `.env` 에서 제거 또는 주석 처리
#   2) 빈 값으로 설정: `NEXT_PUBLIC_DEV_AUTOLOGIN=`
#   3) 빌드 직전 `unset NEXT_PUBLIC_DEV_AUTOLOGIN` 후 실행
# GitHub Actions 등 CI 환경은 별도 secret 설정이 없으면 자동으로 안전.
#
# NEXT_PUBLIC_DEV_AUTOLOGIN=123456

# ========================================
# 외부 서비스 (프로젝트에 맞게 추가)
# ========================================
# API_KEY=

# ========================================
# 빌드 타임 — 한국 법정 공휴일 수집 (Sprint 6 T2-a, ADR-005)
# ========================================
# 공공데이터포털 (data.go.kr) 특일 정보 API 인증키.
# 발급 절차:
#   1) https://www.data.go.kr 회원가입
#   2) "특일 정보" 검색 → 활용신청 → 24시간 내 발급
#   3) 마이페이지 → 인증키 발급현황 → "일반 인증키 (Encoding)" 값 복사
#   4) 아래 변수에 채우기 (`.env` 파일은 .gitignore 됨)
#
# 사용: `pnpm holidays:fetch` (빌드 타임 1회, 앱 런타임은 외부 호출 없음)
# 갱신: 2029-12 이전 재실행 후 V401(+) 신규 마이그레이션 추가
# KOREA_HOLIDAY_API_KEY=
