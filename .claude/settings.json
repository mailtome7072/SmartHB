{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(pnpm *)",
      "Bash(cargo *)",
      "Bash(rustup *)",
      "Bash(sqlx *)",
      "Bash(curl *)",
      "Bash(gh *)",
      "Bash(jq *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretooluse-bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttooluse-code-validator.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttooluse-scope-tracker.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-doc-checker.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "bgIsolation": "none"
  }
}