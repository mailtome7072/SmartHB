{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "SmartHB 기본 권한",
  "windows": ["main", "academic-print"],
  "macos": ["main", "academic-print"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:webview:allow-create-webview-window",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "window-state:default",
    "process:allow-restart"
  ]
}
