#!/usr/bin/env bash
# scripts/hooks/pre-commit
# Harness Engineering 원칙 2: Hook Compliance
#
# git commit 실행 직전 자동 실행되는 진입점이다. 실제 검사 로직은
# `scripts/pre-commit-lint.sh`에 위치하며 본 파일은 위임 wrapper다.
#
# SETUP.sh 가 `git config --local core.hooksPath scripts/hooks` 로 등록한다.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LINT_SCRIPT="$SCRIPT_DIR/../pre-commit-lint.sh"

if [ ! -f "$LINT_SCRIPT" ]; then
  echo "🚫 [pre-commit] scripts/pre-commit-lint.sh 가 존재하지 않습니다."
  echo "   템플릿 파일이 누락된 상태입니다. 저장소를 재클론하거나 파일을 복구하세요."
  exit 1
fi

bash "$LINT_SCRIPT"
exit $?
